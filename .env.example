# Server Port
PORT=3001

# Database Configuration (Defaults to SQLite for zero-config startup)
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/database.sqlite

# Queue Configuration (Disable Redis to use local in-memory background worker runner)
USE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Provider Configurations
# Supported: 'claude' | 'openai' (defaults to 'claude')
AI_PROVIDER=claude
# Add your keys here. If left blank, the system will automatically fallback to high-quality mock QA analyses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local File Storage Configuration (Defaults to local filesystem if R2 credentials are blank)
STORAGE_DIR=./uploads

# Cloudflare R2 Configurations (Optional, uncomment and fill to use R2 instead of local)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=playwright-artifacts
# R2_PUBLIC_URL=

# JWT Secrets for Auth
JWT_SECRET=aia_jwt_secret_key_change_me_in_production

# Frontend Configurations
NEXT_PUBLIC_API_URL=http://localhost:3001
